# Nix profile
export PATH="/nix/var/nix/profiles/default/bin:$PATH"
export XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}:/nix/var/nix/profiles/default/share"
if [[ -z $NIX_SSL_CERT_FILE && -f /etc/ssl/certs/ca-certificates.crt ]]; then
  export NIX_SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
fi

# ssh-agent: start once, reuse env across shells
if [[ -z $SSH_AUTH_SOCK ]]; then
  if [[ -f ~/.cache/ssh-agent.env ]]; then
    source ~/.cache/ssh-agent.env >/dev/null
  fi
  if ! kill -0 "${SSH_AGENT_PID:-0}" 2>/dev/null; then
    ssh-agent -s > ~/.cache/ssh-agent.env
    source ~/.cache/ssh-agent.env >/dev/null
  fi
fi

