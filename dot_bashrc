# jj bookmark set + push
jp() {
  local bookmark="${1:-master}"
  jj bookmark set "$bookmark" && jj git push --bookmark "$bookmark"
}

# format, lint, typecheck, test — in parallel by default
# trinity [-s|--sequential] [--ci]
trinity() {
  local sequential=0 ci=0 arg
  for arg in "$@"; do
    case "$arg" in
      -s|--sequential) sequential=1 ;;
      --ci) ci=1 ;;
    esac
  done
  local cmds=(
    'uv run ruff format'
    'uv run ruff check --fix'
    'uv run ty check'
    'uv run pytest'
  )
  local failed=0 code cmd
  if (( sequential )); then
    for cmd in "${cmds[@]}"; do
      echo "▶ $cmd"
      bash -lc "$cmd"
      code=$?
      (( code != 0 )) && failed=1
    done
  else
    local tmp i=0
    tmp=$(mktemp -d)
    for cmd in "${cmds[@]}"; do
      ( bash -lc "$cmd" > "$tmp/$i.out" 2>&1; echo $? > "$tmp/$i.code" ) &
      i=$((i + 1))
    done
    wait
    i=0
    for cmd in "${cmds[@]}"; do
      code=$(< "$tmp/$i.code")
      echo "▶ $cmd (exit $code)"
      cat "$tmp/$i.out"
      (( code != 0 )) && failed=1
      i=$((i + 1))
    done
    rm -rf "$tmp"
  fi
  if (( failed )); then
    echo "❌ one or more steps failed."
    (( ci )) && return 1
    return 0
  fi
  echo "✅ all steps passed."
}

