{{ if .omarchy.enabled -}}
source = ~/.config/omarchy/current/theme/hyprlock.conf
{{ end }}
general {
    ignore_empty_input = true
}

background {
    monitor =
    color = $color
{{ if .omarchy.enabled }}    path = ~/.config/omarchy/current/background
{{ end }}    blur_passes = 3
}

animations {
    enabled = false
}

input-field {
    monitor =
    size = 650, 100
    position = 0, 0
    halign = center
    valign = center

    inner_color = $inner_color
    outer_color = $outer_color
    outline_thickness = 4

    font_family = Mononoki Nerd Font Mono
    font_color = $font_color

    placeholder_text = <span> Enter Password 󰈷 </span>
    check_color = $check_color
    fail_text = <i>$FAIL ($ATTEMPTS)</i>

    rounding = 0
    shadow_passes = 0
    fade_on_empty = false
}

auth {
    fingerprint:enabled = true
}
