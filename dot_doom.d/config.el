(setq shell-file-name (executable-find "bash"))

(setq projectile-project-search-path '("~/Documents/Work") projectile-sort-order 'recentf)
(map! :leader :desc "Change window" "b o" #'other-window)
(map! :leader :desc "Kill buffer" "k" #'kill-this-buffer)

;; projectile and workspace tabs working together >:]
(defun qd/rename-workspace-to-project ()
  (when (and (fboundp '+workspace-rename)
             (or (string= (+workspace-current-name) "main")
                 (string= (+workspace-current-name) "default")
                 (string= (+workspace-current-name) "unnamed")))
    (when-let* ((root (projectile-project-root))
                (proj-name (projectile-project-name))
                (curr-name (+workspace-current-name)))
      (+workspace-rename curr-name proj-name))))

(setq shell-file-name (executable-find "nu")) ;; doom doctor said this.

